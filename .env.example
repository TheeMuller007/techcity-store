# ============================================
# TechCity Store — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Supabase Database (cloud) ---
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI (Transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# --- JWT Secret ---
JWT_SECRET=replace-with-a-long-random-secret

# --- Server Port (local dev only, Render sets this automatically) ---
PORT=5000

# --- Local Postgres fallback (only used if DATABASE_URL is not set) ---
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=techcity_db
DB_PORT=5432

# --- Optional: Email notifications ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
